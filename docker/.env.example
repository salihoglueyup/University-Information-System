# ==========================================
# UBIS — Development Environment Variables
# ==========================================
# Copy this file to docker/.env before running:
#   cd docker && docker compose up
#
# Variables marked [REQUIRED] must be set.
# Variables marked [OPTIONAL] have sensible defaults.

# --- Application Secrets ---
# [OPTIONAL] Dev-only fallback. Change for any shared environment.
JWT_SEC=ubis_jwt_secret_dev_only
CSRF_SECRET=ubis_csrf_secret_dev_only

# --- MeiliSearch ---
# [OPTIONAL] Leave empty to run MeiliSearch without an API key in dev.
MEILI_MASTER_KEY=

# --- Host Ports ---
# [OPTIONAL] Change if the default port is already in use on your machine.
SERVER_PORT=5000

# --- Client ---
# [OPTIONAL] Override the API base URL the Vite dev server uses.
VITE_API_URL=http://localhost:5000

# --- Monitoring (activate with: docker compose --profile monitoring up) ---
# [OPTIONAL]
GRAFANA_ADMIN_PASSWORD=admin
