# Copy this file to docker/.env before running development compose.

# Optional for local development. Keep empty to run MeiliSearch without API key.
MEILI_MASTER_KEY=

# Optional client-side API base URL override (normally defaults to localhost:5000).
VITE_API_URL=http://localhost:5000

# Host port for backend container (change to 5001 if 5000 is busy).
SERVER_PORT=5000
