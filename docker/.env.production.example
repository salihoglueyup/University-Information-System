# ==========================================
# UBIS — Production Environment Variables
# ==========================================
# Copy this file to docker/.env.production before deploying:
#   cd docker && docker compose -f docker-compose.prod.yml up -d
#
# ⚠️  ALL [REQUIRED] variables MUST be replaced with strong,
#     unique values before the first deployment.

# --- Security [REQUIRED] ---
JWT_SEC=REPLACE_WITH_STRONG_RANDOM_SECRET_MIN_32_CHARS
CSRF_SECRET=REPLACE_WITH_ANOTHER_STRONG_RANDOM_SECRET

# --- MongoDB [REQUIRED] ---
MONGO_ROOT_USER=admin
MONGO_ROOT_PASSWORD=REPLACE_WITH_STRONG_ROOT_PASSWORD
MONGO_APP_USER=ubis_user
MONGO_APP_PASSWORD=REPLACE_WITH_STRONG_APP_PASSWORD

# --- MeiliSearch [REQUIRED] ---
MEILI_MASTER_KEY=REPLACE_WITH_STRONG_MEILI_KEY

# --- Redis [REQUIRED] ---
REDIS_PASSWORD=REPLACE_WITH_STRONG_REDIS_PASSWORD

# --- Client ---
CLIENT_URL=http://localhost
CLIENT_PORT=80

# --- Server ---
SERVER_PORT=5001

# --- Monitoring (Optional) ---
GRAFANA_ADMIN_PASSWORD=REPLACE_WITH_GRAFANA_PASSWORD
